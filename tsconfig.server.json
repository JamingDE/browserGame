{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-server",
    "rootDir": ".",
    "sourceMap": false,
    "declaration": false
  },
  "include": ["server", "shared"],
  "exclude": ["node_modules", "dist", "dist-server", "src"]
}
